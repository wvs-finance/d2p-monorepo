# Base mainnet archive RPC for fork tests (Alchemy/dRPC/Dwellir free tier serve archive).
BASE_RPC_URL=
# NOTE: the fork block is pinned as a Solidity `uint256 constant BASE_FORK_BLOCK` in the test source
# (test/fork/BaseForkHarness.t.sol), NOT here. Re-pin there if the RPC cannot serve that block.
# Verified pinned value: the BASE_FORK_BLOCK constant is 46700000 (archive-confirmed:
# PoolManager 0x498581...2b2b and USDC 0x833589...2913 both have code at this Base block).
# Existing Somnia testnet keys (do NOT commit real values):
SOMNIA_TESTNET_ADDRESS=
SOMNIA_TESTNET_PK=
# Alchemy key for the in-VM Polygon fork tests (vm.rpcUrl("polygon")):
ALCHEMY_API_KEY=
# BuildBear Sandbox — hosted Polygon fork (chainId 31337) for the UI-visible demo mint; the single
# sandbox RPC carries the buildbear_* cheats (no separate admin RPC); bearer secret, server-side ONLY,
# gitignored, 3-day free TTL (create within 72h of the demo). BUILDBEAR_DEPLOYER_PK is the broadcast
# sender the runner funds via buildbear_ERC20Faucet BEFORE the single broadcast — env-sourced, never hardcoded.
BUILDBEAR_RPC_URL=
BUILDBEAR_DEPLOYER_PK=
# Inlined Panoptic-core cold deploy reads these via vm.envAddress (the runner exports them as OS env):
UNIV4_POOL_MANAGER=
UNIV3_FACTORY=
GUARDIAN_ADMIN=
TREASURER=
