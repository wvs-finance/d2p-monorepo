# Foundry build artifacts (anchored to the contracts root so metadata/out/ is NOT swept up)
/out/
/cache/
/broadcast/

# NFT metadata package — a deterministic build artifact required by DeployProtocol's deploy path
# on a fresh checkout (the fork-state snapshot is local-only). Re-include it despite the root
# `out/` ignore so the fork test is reproducible in CI.
!metadata/out/
!metadata/out/MetadataPackage.json

# Vendored Foundry deps are COMMITTED as plain files in the monorepo (no submodules,
# no `forge install` needed for a plain clone). The blanket `lib/` ignore is removed
# on purpose. Keep out/cache/broadcast ignored above.
# (lib/v4-hooks-public/lib is excluded from the vendor set — that tree is compile-skipped
#  in foundry.toml and imported by nothing; see README.)

# Secrets — never commit real values (.env.example documents key names only)
.env
!.env.example

# Fork-state snapshots (vm.dumpState) — deterministic, regenerable; no secrets
fork-state/
