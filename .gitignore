# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/.lighthouseci

# Playwright MCP transient session artifacts (DOM snapshots, console logs,
# Evidence Collector screenshots). Per CLAUDE.md these are transient evidence
# referenced from verification reports by path, not committed.
/.playwright-mcp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example, ignore everything else
.env.local
.env*.local

# velite generated output
/.velite/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
