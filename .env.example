# ===========================================================================
# WVS Finance Frontend — Environment Variables
# ===========================================================================
# Naming convention:
#   - NEXT_PUBLIC_*  -> safe to leak to the browser bundle.
#                       Use for: chain IDs, public RPC URLs, WalletConnect ID,
#                       and the canonical app URL.
#   - Anything else  -> server-only. Never prefix with NEXT_PUBLIC_.
#                       Use for: API keys, HuggingFace tokens, AI provider
#                       secrets, private RPC endpoints.
#
# Vercel scope strategy:
#   - Production  -> live values for wvs.finance (production domain).
#   - Preview     -> preview RPCs (rate-limited free tiers acceptable).
#   - Development -> local fallback values (public RPCs, localhost URL).
# ===========================================================================

# ---- Public RPC primaries (Production / Preview / Development) ----
# Celo mainnet is the primary chain for deployed instruments.
NEXT_PUBLIC_RPC_CELO_PRIMARY="https://forno.celo.org"

# Secondary chains
NEXT_PUBLIC_RPC_ETH_PRIMARY="https://ethereum.publicnode.com"
NEXT_PUBLIC_RPC_BASE_PRIMARY="https://mainnet.base.org"
NEXT_PUBLIC_RPC_ARB_PRIMARY="https://arb1.arbitrum.io/rpc"
NEXT_PUBLIC_RPC_OP_PRIMARY="https://mainnet.optimism.io"

# ---- WalletConnect ----
# Get your project ID at https://cloud.walletconnect.com
# Safe to commit: WalletConnect requires it to be public (origin-restricted on their end).
# Production: production project ID.
# Preview / Development: the same ID is acceptable (origin restriction handles it).
NEXT_PUBLIC_WALLETCONNECT_ID="REPLACE_ME_FROM_CLOUD_WALLETCONNECT_COM"

# ---- App URL ----
# Production: https://wvs.finance
# Preview:    Vercel sets VERCEL_URL automatically; for Playwright use PLAYWRIGHT_TEST_BASE_URL.
# Development: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Phase 9: Agent-1 Somnia operator route (server-only — NEVER NEXT_PUBLIC_)
# ---------------------------------------------------------------------------

# Private key for the Somnia testnet operator account.
# SECURITY:
#   - Server-only. Never set as NEXT_PUBLIC_. Never commit a real value here.
#   - The /api/abrigo/agent1 route 503s when this is absent (non-operator-deploy guard).
#   - Required: a funded Somnia testnet account with >50 STT
#     (each two-leg run spends ~0.9–1.0 STT in inference deposits).
# Format: 64-char hex private key with 0x prefix.
SOMNIA_OPERATOR_PK=

# Shared secret for the POST /api/abrigo/agent1 route.
# The route validates the x-agent1-secret request header against this value.
# The route returns 401 on header mismatch and 503 when this var is absent.
# Non-operator deploys (staging, preview, production without operator keys)
# MUST leave both SOMNIA_OPERATOR_PK and AGENT1_ROUTE_SECRET unset so the
# route returns 503 rather than exposing the endpoint unauthenticated.
AGENT1_ROUTE_SECRET=
