{
  "name": "d2p-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "velite build",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test:quick": "biome check . && tsc --noEmit && vitest run",
    "test:all": "pnpm test:quick && pnpm playwright test && pnpm lhci autorun",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --project=chromium",
    "test:a11y": "playwright test tests/a11y/",
    "test:lighthouse": "lhci autorun",
    "test:impeccable": "npx impeccable detect app/",
    "prepare": "lefthook install",
    "contracts:gen": "wagmi generate",
    "somnia:capture": "npx tsx lib/apps/abrigo/somnia/capture-snapshot.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "7.3.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.100.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "katex": "0.17.0",
    "lucide-react": "^1.14.0",
    "mcp-handler": "^1.1.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "next-intl": "^4.11.2",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "rehype-autolink-headings": "7.1.0",
    "rehype-katex": "7.0.1",
    "rehype-slug": "6.0.0",
    "remark-directive": "4.0.0",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "schema-dts": "^2.0.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "5.1.0",
    "velite": "^0.3.1",
    "viem": "^2.48.11",
    "wagmi": "^2.19.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^1.9.4",
    "@commitlint/config-conventional": "^21.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@wagmi/cli": "^2.10.0",
    "commitlint": "^21.0.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "msw": "^2.14.6",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@parcel/watcher",
      "@swc/core",
      "bufferutil",
      "esbuild",
      "keccak",
      "lefthook",
      "msw",
      "utf-8-validate"
    ],
    "ignoredBuiltDependencies": ["sharp", "unrs-resolver"]
  }
}
