{
  "te/colombia/inflation":        { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "HistoricalDataSymbol", "match": "COCPIYOY",       "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 2, "kind": "Uint" },
  "te/colombia/interest-rate":    { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "HistoricalDataSymbol", "match": "CORRRMIN",       "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 2, "kind": "Uint" },
  "te/colombia/gdp-growth":       { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "HistoricalDataSymbol", "match": "COCIPIBY",       "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 1, "kind": "Int"  },
  "te/colombia/unemployment":     { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "HistoricalDataSymbol", "match": "COUNTOTR",       "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 1, "kind": "Uint" },
  "te/colombia/bond-10y":         { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "HistoricalDataSymbol", "match": "COGR10Y",        "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 1, "kind": "Uint" },
  "te/colombia/balance-of-trade": { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "HistoricalDataSymbol", "match": "COTRBALM",       "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "USD Billion", "decimals": 2, "kind": "Int"  },
  "te/colombia/capacity-utilization": { "teEndpoint": "country/colombia",       "extract": { "type": "array-filter", "field": "HistoricalDataSymbol", "match": "COLOMBIACAPUTI", "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 1, "kind": "Uint" },
  "te/fx/usdcop":                 { "teEndpoint": "markets/currency?cross=USD", "extract": { "type": "array-filter", "field": "Symbol",   "match": "USDCOP:CUR", "value": "Last", "tsField": "Date" }, "unit": "COP/USD",   "decimals": 2, "kind": "Uint" },
  "te/commodity/crude-oil":       { "teEndpoint": "markets/commodity",          "extract": { "type": "array-filter", "field": "Name",     "match": "Crude Oil",  "value": "Last", "tsField": "Date" }, "unit": "USD/Bbl",   "decimals": 3, "kind": "Uint" },
  "te/commodity/natural-gas":     { "teEndpoint": "markets/commodity",          "extract": { "type": "array-filter", "field": "Name",     "match": "Natural gas","value": "Last", "tsField": "Date" }, "unit": "USD/MMBtu", "decimals": 4, "kind": "Uint" },
  "te/commodity/gold":            { "teEndpoint": "markets/commodity",          "extract": { "type": "array-filter", "field": "Name",     "match": "Gold",       "value": "Last", "tsField": "Date" }, "unit": "USD/t.oz",  "decimals": 2, "kind": "Uint" }
}
