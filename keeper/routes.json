{
  "te/colombia/inflation":        { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "Category", "match": "Inflation Rate",          "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 2, "kind": "Uint" },
  "te/colombia/interest-rate":    { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "Category", "match": "Interest Rate",            "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 2, "kind": "Uint" },
  "te/colombia/gdp-growth":       { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "Category", "match": "GDP Annual Growth Rate",   "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 1, "kind": "Int"  },
  "te/colombia/unemployment":     { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "Category", "match": "Unemployment Rate",        "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 1, "kind": "Uint" },
  "te/colombia/bond-10y":         { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "Category", "match": "Government Bond 10Y",      "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "percent",     "decimals": 1, "kind": "Uint" },
  "te/colombia/balance-of-trade": { "teEndpoint": "country/colombia",           "extract": { "type": "array-filter", "field": "Category", "match": "Balance of Trade",         "value": "LatestValue", "tsField": "LatestValueDate" }, "unit": "USD Billion", "decimals": 2, "kind": "Int"  },
  "te/fx/usdcop":                 { "teEndpoint": "markets/currency?cross=USD", "extract": { "type": "array-filter", "field": "Symbol",   "match": "USDCOP:CUR",              "value": "Last",        "tsField": "Date" },           "unit": "COP/USD",     "decimals": 2, "kind": "Uint" },
  "te/commodity/crude-oil":       { "teEndpoint": "markets/commodity",          "extract": { "type": "array-filter", "field": "Name",     "match": "Crude Oil",               "value": "Last",        "tsField": "Date" },           "unit": "USD/Bbl",     "decimals": 3, "kind": "Uint" },
  "te/commodity/natural-gas":     { "teEndpoint": "markets/commodity",          "extract": { "type": "array-filter", "field": "Name",     "match": "Natural gas",             "value": "Last",        "tsField": "Date" },           "unit": "USD/MMBtu",   "decimals": 4, "kind": "Uint" },
  "te/commodity/gold":            { "teEndpoint": "markets/commodity",          "extract": { "type": "array-filter", "field": "Name",     "match": "Gold",                    "value": "Last",        "tsField": "Date" },           "unit": "USD/t.oz",    "decimals": 2, "kind": "Uint" }
}
